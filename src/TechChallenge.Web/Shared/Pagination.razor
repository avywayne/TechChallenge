@typeparam T

@if (Result.TotalPages > 1)
{
    <div class="pagination">
        <span class="pagination-info">
            Showing @((Result.Page - 1) * Result.PageSize + 1)–@(Math.Min(Result.Page * Result.PageSize, Result.TotalCount)) of @Result.TotalCount
        </span>

        <div class="pagination-controls">
            <button class="page-btn" @onclick="() => OnPageChange.InvokeAsync(1)"
                    disabled="@(!Result.HasPrevious)" aria-label="First page">«</button>
            <button class="page-btn" @onclick="() => OnPageChange.InvokeAsync(Result.Page - 1)"
                    disabled="@(!Result.HasPrevious)" aria-label="Previous page">‹</button>

            @foreach (var p in GetPageNumbers())
            {
                @if (p == -1)
                {
                    <span class="page-ellipsis">…</span>
                }
                else
                {
                    <button class="page-btn @(p == Result.Page ? "active" : "")"
                            @onclick="() => OnPageChange.InvokeAsync(p)">
                        @p
                    </button>
                }
            }

            <button class="page-btn" @onclick="() => OnPageChange.InvokeAsync(Result.Page + 1)"
                    disabled="@(!Result.HasNext)" aria-label="Next page">›</button>
            <button class="page-btn" @onclick="() => OnPageChange.InvokeAsync(Result.TotalPages)"
                    disabled="@(!Result.HasNext)" aria-label="Last page">»</button>
        </div>
    </div>
}

<style>
    .pagination {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 14px;
        border-top: 1px solid var(--border);
        flex-wrap: wrap;
        gap: 8px;
    }

    .pagination-info {
        font-size: 12px;
        color: var(--text-muted);
    }

    .pagination-controls {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .page-btn {
        min-width: 32px;
        height: 32px;
        padding: 0 8px;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        background: var(--bg-card);
        color: var(--text);
        font-size: 13px;
        cursor: pointer;
        transition: background .15s, border-color .15s;
    }

    .page-btn:hover:not(:disabled) {
        background: var(--bg-hover);
        border-color: var(--accent);
    }

    .page-btn.active {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff;
        font-weight: 700;
    }

    .page-btn:disabled {
        opacity: 0.35;
        cursor: not-allowed;
    }

    .page-ellipsis {
        padding: 0 4px;
        color: var(--text-muted);
        font-size: 13px;
    }
</style>

@code {
    [Parameter, EditorRequired] public PagedResult<T>           Result       { get; set; } = null!;
    [Parameter, EditorRequired] public EventCallback<int>       OnPageChange { get; set; }

    /// <summary>
    /// Generates a smart page number list with ellipsis for large page counts.
    /// Example for page 5 of 20: [1, …, 4, 5, 6, …, 20]
    /// </summary>
    private IEnumerable<int> GetPageNumbers()
    {
        var total   = Result.TotalPages;
        var current = Result.Page;
        var pages   = new List<int>();

        if (total <= 7)
        {
            // Show all pages if total is small
            return Enumerable.Range(1, total);
        }

        pages.Add(1);

        if (current > 3) pages.Add(-1); // ellipsis

        for (var i = Math.Max(2, current - 1); i <= Math.Min(total - 1, current + 1); i++)
            pages.Add(i);

        if (current < total - 2) pages.Add(-1); // ellipsis

        pages.Add(total);

        return pages;
    }
}