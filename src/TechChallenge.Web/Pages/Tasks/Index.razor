    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Title is required.")]
        [System.ComponentModel.DataAnnotations.MaxLength(120, ErrorMessage = "Title cannot exceed 120 characters.")]
        public string Title { get; set; } = "";

        [System.ComponentModel.DataAnnotations.MaxLength(2000, ErrorMessage = "Description cannot exceed 2000 characters.")]
        public string? Description { get; set; }

        public TaskPriority Priority { get; set; } = TaskPriority.Medium;

        [System.ComponentModel.DataAnnotations.Range(1, int.MaxValue, ErrorMessage = "Please select a project.")]
        public int ProjectId { get; set; } = 0;

        public int?      AssigneeId { get; set; }
        public DateOnly? DueDate    { get; set; }

        [System.ComponentModel.DataAnnotations.Range(0.1, 9999, ErrorMessage = "Estimated hours must be between 0.1 and 9999.")]
        public decimal? EstimatedHours { get; set; }

        [System.ComponentModel.DataAnnotations.Range(0.1, 9999, ErrorMessage = "Actual hours must be between 0.1 and 9999.")]
        public decimal? ActualHours { get; set; }
    }
