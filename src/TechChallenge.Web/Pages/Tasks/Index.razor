@code {
    // State
    private bool    _loading  = true;
    private bool    _saving   = false;
    private bool    _isError  = false;
    private string  _viewMode = "table";
    private string? _message;

    private string?       _search           = null;
    private int?          _filterProjectId  = null;
    private TaskStatus?   _filterStatus     = null;
    private TaskPriority? _filterPriority   = null;
    private int?          _filterAssigneeId = null;
    private string?       _sortBy           = null;

    private bool     _showModal = false;
    private int?     _editId    = null;
    private string?  _formError = null;
    private TaskForm _form      = new();

    private bool      _showTransitionModal = false;
    private TaskItem? _transitionTask      = null;
    private string?   _transitionError     = null;

    private bool      _showDeleteModal = false;
    private TaskItem? _deleteTarget    = null;

    // Drag & Drop
    private bool        _dragging       = false;
    private int?        _draggingTaskId = null;
    private TaskStatus? _dragOverStatus = null;
    private TaskItem?   _draggingTask   = null;

    // Pagination
    private PagedResult<TaskItem> _result = new(new(), 0, 1, 15);
    private List<TaskItem> _tasks => _result.Items;
    private int _page = 1;
    private const int PageSize = 15;

    private List<Project>    _projects = new();
    private List<TeamMember> _members  = new();

    // Subtask state
    private HashSet<int>                    _expandedTasks   = new();
    private Dictionary<int, List<TaskItem>> _subTasks        = new();
    private Dictionary<int, string>         _newSubTaskTitle = new();
    private Dictionary<int, bool>           _savingSubTask   = new();

    // Lifecycle
    protected override async Task OnInitializedAsync()
    {
        await LoadRefsAsync();
        await LoadAsync();
    }

    /// <summary>Loads projects and members for filter dropdowns and forms.</summary>
    private async Task LoadRefsAsync()
    {
        var projectResult = await ProjectService.ListAsync(includeArchived: false, pageSize: 1000);
        _projects = projectResult.Items;

        var memberResult = await MemberService.ListAsync(onlyActive: false, pageSize: 1000);
        _members = memberResult.Items;
    }

    /// <summary>Reloads the task list applying all active filters and pagination.</summary>
    private async Task LoadAsync()
    {
        _loading = true;
        _result = await TaskService.ListAsync(
            projectId:  _filterProjectId,
            status:     _filterStatus,
            priority:   _filterPriority,
            assigneeId: _filterAssigneeId,
            search:     _search,
            sortBy:     _sortBy,
            page:       _page,
            pageSize:   PageSize);
        _loading = false;
    }

    /// <summary>Resets to page 1 and reloads when any filter changes.</summary>
    private async Task FilterChangedAsync() { _page = 1; await LoadAsync(); }

    private async Task GoToPageAsync(int page) { _page = page; await LoadAsync(); }

    /// <summary>Switches view mode and reloads tasks.</summary>
    private async Task SetViewMode(string mode) { _viewMode = mode; await LoadAsync(); }

    // Subtask handlers

    /// <summary>
    /// Toggles the subtask panel. Loads from server on first expand.
    /// </summary>
    private async Task ToggleSubTasksAsync(TaskItem task)
    {
        if (_expandedTasks.Contains(task.Id))
        {
            _expandedTasks.Remove(task.Id);
            return;
        }

        _expandedTasks.Add(task.Id);

        if (!_subTasks.ContainsKey(task.Id))
            _subTasks[task.Id] = await TaskService.GetSubTasksAsync(task.Id);

        if (!_newSubTaskTitle.ContainsKey(task.Id))
            _newSubTaskTitle[task.Id] = "";
    }

    /// <summary>Creates a subtask inline and refreshes the list.</summary>
    private async Task AddSubTaskAsync(TaskItem parent)
    {
        var title = _newSubTaskTitle.GetValueOrDefault(parent.Id, "").Trim();
        if (string.IsNullOrEmpty(title)) return;

        _savingSubTask[parent.Id] = true;

        await TaskService.CreateSubTaskAsync(parent.Id, new TaskItem
        {
            Title    = title,
            Priority = TaskPriority.Medium,
        });

        _newSubTaskTitle[parent.Id] = "";
        _subTasks[parent.Id]        = await TaskService.GetSubTasksAsync(parent.Id);
        _savingSubTask[parent.Id]   = false;

        await LoadAsync();
    }

    /// <summary>Cycles subtask status: Backlog -> InProgress -> Done -> Backlog.</summary>
    private async Task CycleSubTaskStatusAsync(TaskItem subTask, int parentId)
    {
        var next = subTask.Status switch
        {
            TaskStatus.Backlog    => TaskStatus.InProgress,
            TaskStatus.InProgress => TaskStatus.Done,
            _                     => TaskStatus.Backlog
        };

        // Optimistic update
        var old = subTask.Status;
        subTask.Status = next;
        StateHasChanged();

        // Bypass state machine for subtasks — use direct update
        var entity = new TaskItem
        {
            Id             = subTask.Id,
            Title          = subTask.Title,
            Description    = subTask.Description,
            Priority       = subTask.Priority,
            ProjectId      = subTask.ProjectId,
            AssigneeId     = subTask.AssigneeId,
            DueDate        = subTask.DueDate,
            EstimatedHours = subTask.EstimatedHours,
            ActualHours    = subTask.ActualHours,
            Status         = next,
        };

        var (ok, err) = await TaskService.ChangeStatusAsync(subTask.Id, next, reason: "Subtask cycle");
        if (!ok)
        {
            subTask.Status = old;
            StateHasChanged();
            ShowToastAsync(err ?? "Could not update subtask status.", true);
        }
        else
        {
            _subTasks[parentId] = await TaskService.GetSubTasksAsync(parentId);
        }
    }
    /// <summary>Deletes a subtask and refreshes the parent list.</summary>
    private async Task DeleteSubTaskAsync(int subTaskId, int parentId)
    {
        await TaskService.DeleteSubTaskAsync(subTaskId);
        _subTasks[parentId] = await TaskService.GetSubTasksAsync(parentId);
        await LoadAsync();
    }

    /// <summary>Returns "done/total" progress string for a task's subtasks.</summary>
    private string SubTaskProgress(TaskItem task)
    {
        if (!task.SubTasks.Any()) return "";
        var done = task.SubTasks.Count(s => s.Status == TaskStatus.Done);
        return $"{done}/{task.SubTasks.Count}";
    }

    /// <summary>Returns badge CSS class based on subtask completion ratio.</summary>
    private string SubTaskBadgeClass(TaskItem task)
    {
        if (!task.SubTasks.Any()) return "badge-backlog";
        var done = task.SubTasks.Count(s => s.Status == TaskStatus.Done);
        if (done == task.SubTasks.Count) return "badge-done";
        if (done > 0) return "badge-inprogress";
        return "badge-backlog";
    }

    private void OnSubTaskInput(ChangeEventArgs e, int taskId)
    {
        _newSubTaskTitle[taskId] = e.Value?.ToString() ?? string.Empty;
    }

    private static string GetSubTaskToggleTitle(bool expanded) =>
    expanded ? "Hide subtasks" : "Show subtasks";

    // Drag & Drop

    private void OnDragStart(TaskItem task)
    {
        _dragging       = true;
        _draggingTask   = task;
        _draggingTaskId = task.Id;
    }

    private void OnDragEnter(TaskStatus status) => _dragOverStatus = status;
    private void OnDragLeave() { }

    private async Task OnDrop(TaskStatus targetStatus)
    {
        _dragOverStatus = null;
        _dragging       = false;

        if (_draggingTask is null) return;
        if (_draggingTask.Status == targetStatus)
        {
            _draggingTask   = null;
            _draggingTaskId = null;
            return;
        }

        // Check if reason required — can't do optimistic for these via DnD
        if (StateMachine.RequiresReason(_draggingTask.Status, targetStatus))
        {
            _transitionTask  = _draggingTask;
            _pendingStatus   = targetStatus;
            _reasonInput     = null;
            _reasonError     = null;
            _showReasonModal = true;
            _draggingTask    = null;
            _draggingTaskId  = null;
            return;
        }

        // Optimistic update
        var task      = _draggingTask;
        var oldStatus = task.Status;
        task.Status   = targetStatus;

        _draggingTask   = null;
        _draggingTaskId = null;
        StateHasChanged();

        var (ok, err) = await TaskService.ChangeStatusAsync(task.Id, targetStatus, null);

        if (ok)
        {
             ShowToastAsync($"Moved to {targetStatus}.", isError: false);
        }
        else
        {
            // Revert on failure
            task.Status = oldStatus;
             ShowToastAsync($"⚠️ {err}", isError: true);
        }
    }

    private void OnDragEnd()
    {
        _dragging       = false;
        _draggingTaskId = null;
        _draggingTask   = null;
        _dragOverStatus = null;
    }

    // Create / Edit modal

    private void OpenCreate()
    {
        _form      = new();
        _editId    = null;
        _formError = null;
        _showModal = true;
    }

    private void OpenCreateWithStatus(TaskStatus status)
    {
        _form      = new TaskForm { Priority = TaskPriority.Medium };
        _editId    = null;
        _formError = null;
        _showModal = true;
    }

    private void OpenEdit(TaskItem t)
    {
        _form = new TaskForm
        {
            Title          = t.Title,
            Description    = t.Description,
            Priority       = t.Priority,
            ProjectId      = t.ProjectId,
            AssigneeId     = t.AssigneeId,
            DueDate        = t.DueDate.HasValue
                                ? DateOnly.FromDateTime(t.DueDate.Value.ToLocalTime())
                                : null,
            EstimatedHours = t.EstimatedHours,
            ActualHours    = t.ActualHours
        };
        _editId    = t.Id;
        _formError = null;
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

private async Task SaveAsync()
{
    _saving    = true;
    _formError = null;

    var task = new TaskItem
    {
        Id             = _editId ?? 0,
        Title          = _form.Title.Trim(),
        Description    = string.IsNullOrWhiteSpace(_form.Description) ? null : _form.Description.Trim(),
        Priority       = _form.Priority,
        ProjectId      = _form.ProjectId,
        AssigneeId     = _form.AssigneeId,
        DueDate        = _form.DueDate.HasValue
                            ? DateTime.SpecifyKind(
                                _form.DueDate.Value.ToDateTime(TimeOnly.MinValue),
                                DateTimeKind.Local).ToUniversalTime()
                            : null,
        EstimatedHours = _form.EstimatedHours,
        ActualHours    = _form.ActualHours
    };

    if (_editId is null)
    {
        await TaskService.CreateAsync(task);
         ShowToastAsync("Task created successfully.", isError: false);
        _saving    = false;
        _showModal = false;
        await LoadAsync();
    }
    else
    {
        try
        {
            var result = await TaskService.UpdateAsync(task);
            if (result is null)
            {
                _formError = "Task not found. It may have been deleted.";
                _saving = false;
                return;
            }

            // Optimistic update — reflect changes in memory immediately
            var existing = _tasks.FirstOrDefault(t => t.Id == _editId);
            if (existing is not null)
            {
                existing.Title          = task.Title;
                existing.Description    = task.Description;
                existing.Priority       = task.Priority;
                existing.ProjectId      = task.ProjectId;
                existing.Project        = _projects.FirstOrDefault(p => p.Id == task.ProjectId);
                existing.AssigneeId     = task.AssigneeId;
                existing.Assignee       = _members.FirstOrDefault(m => m.Id == task.AssigneeId);
                existing.DueDate        = task.DueDate;
                existing.EstimatedHours = task.EstimatedHours;
                existing.ActualHours    = task.ActualHours;
            }

             ShowToastAsync("Task updated successfully.", isError: false);
        }
        catch (InvalidOperationException ex)
        {
            _formError = ex.Message;
            _saving = false;
            return;
        }

        _saving    = false;
        _showModal = false;
    }
}
    // Status transition modal

    private void OpenTransition(TaskItem t)
    {
        _transitionTask      = t;
        _transitionError     = null;
        _showTransitionModal = true;
    }

    private void CloseTransitionModal()
    {
        _showTransitionModal = false;
        _transitionTask      = null;
        _transitionError     = null;
    }

private async Task ApplyTransitionAsync(TaskStatus newStatus)
{
    if (_transitionTask is null) return;

    if (StateMachine.RequiresReason(_transitionTask.Status, newStatus))
    {
        _pendingStatus   = newStatus;
        _reasonInput     = null;
        _reasonError     = null;
        _showReasonModal = true;
        return;
    }

    await ExecuteTransitionAsync(newStatus, null);
}

    private async Task ExecuteTransitionAsync(TaskStatus newStatus, string? reason)
    {
        if (_transitionTask is null) return;

        // Optimistic update — change status in memory immediately
        var task        = _transitionTask;
        var oldStatus   = task.Status;
        task.Status     = newStatus;

        if (StateMachine.IsFastClose(oldStatus, newStatus))
        {
            task.IsFastClosed = true;
            task.CloseReason  = reason;
        }
        if (newStatus == TaskStatus.Backlog)
        {
            task.IsFastClosed = false;
            task.CloseReason  = null;
        }

        CloseTransitionModal();
        StateHasChanged();

        // Sync with server in background
        var (ok, err) = await TaskService.ChangeStatusAsync(task.Id, newStatus, reason);

        if (ok)
        {
             ShowToastAsync($"Status updated to {newStatus}.", isError: false);
        }
        else
        {
            // Revert on failure
            task.Status       = oldStatus;
            task.IsFastClosed = false;
            task.CloseReason  = null;
             ShowToastAsync($"⚠️ {err}", isError: true);
        }
    }

    private async Task ConfirmReasonAsync()
    {
        if (string.IsNullOrWhiteSpace(_reasonInput))
        {
            _reasonError = "Please select or enter a reason.";
            return;
        }

        var reason = _reasonInput;
        _showReasonModal = false;
        await ExecuteTransitionAsync(_pendingStatus, reason);
    }

    // Delete modal

    private void ConfirmDelete(TaskItem t) { _deleteTarget = t; _showDeleteModal = true; }
    private void CloseDeleteModal()        { _showDeleteModal = false; _deleteTarget = null; }

    private async Task DeleteAsync()
    {
        if (_deleteTarget is null) return;
        _saving = true;
        await TaskService.DeleteAsync(_deleteTarget.Id);
        _saving = false;
        CloseDeleteModal();
         ShowToastAsync("Task deleted.", isError: false);
        await LoadAsync();
    }

    // Helpers

    private IReadOnlyList<StateTransition> GetAvailableTransitions(TaskStatus current)
        => StateMachine.GetAvailableTransitions(current);

    private static string TransitionBtnClass(TaskStatus to) => to switch
    {
        TaskStatus.Done       => "btn-success",
        TaskStatus.Blocked    => "btn-danger",
        TaskStatus.InProgress => "btn-primary",
        TaskStatus.Backlog    => "btn-ghost",
        _                     => "btn-ghost"
    };

    private static string TransitionIcon(TaskStatus to) => to switch
    {
        TaskStatus.Done       => "✅",
        TaskStatus.Blocked    => "🚧",
        TaskStatus.InProgress => "▶️",
        TaskStatus.Backlog    => "🔄",
        _                     => ""
    };

    private static bool IsOverdue(TaskItem t) =>
        t.Status != TaskStatus.Done &&
        t.DueDate.HasValue &&
        t.DueDate.Value < DateTime.UtcNow;

    private static string Truncate(string? text, int max) =>
        string.IsNullOrEmpty(text) ? "" :
        text.Length <= max ? text : text[..max] + "...";

    private static string GetInitials(string fullName)
    {
        var parts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..1].ToUpper(),
            _ => $"{parts[0][0]}{parts[^1][0]}".ToUpper()
        };
    }

    private static string StatusBadge(TaskStatus s) => s switch
    {
        TaskStatus.Backlog    => "badge-backlog",
        TaskStatus.InProgress => "badge-inprogress",
        TaskStatus.Blocked    => "badge-blocked",
        TaskStatus.Done       => "badge-done",
        _                     => ""
    };

    private static string PriorityBadge(TaskPriority p) => p switch
    {
        TaskPriority.Low      => "badge-low",
        TaskPriority.Medium   => "badge-medium",
        TaskPriority.High     => "badge-high",
        TaskPriority.Critical => "badge-critical",
        _                     => ""
    };

    private void ShowToastAsync(string message, bool isError)
    {
        _message = message;
        _isError = isError;
        StateHasChanged();
        _ = Task.Delay(3000).ContinueWith(_ =>
        {
            _message = null;
            InvokeAsync(StateHasChanged);
        });
    }

    /// <summary>Handles Enter key press in the subtask input to trigger save.</summary>
    private async Task OnSubTaskKeyDown(KeyboardEventArgs e, TaskItem parent)
    {
        if (e.Key == "Enter") await AddSubTaskAsync(parent);
    }

