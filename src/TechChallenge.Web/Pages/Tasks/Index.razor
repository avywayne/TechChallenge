@page "/tasks"
@using TaskStatus = TechChallenge.Web.Models.TaskStatus
@inject ITaskService TaskService
@inject IProjectService ProjectService
@inject ITeamMemberService MemberService
@inject IJSRuntime JS
@inject TaskStateMachine StateMachine

<PageTitle>Tasks - TaskFlow Pro</PageTitle>

<!-- Page header -->
<div class="flex justify-between items-center mb-6">
    <div>
        <h1 style="font-size:22px;font-weight:700;margin-bottom:4px;">Tasks</h1>
        <p class="text-muted">Track and manage all work items</p>
    </div>
    <div class="flex gap-2 items-center">
        <div class="view-toggle">
            <button class="view-toggle-btn @(_viewMode == "table" ? "active" : "")"
                    @onclick='() => SetViewMode("table")'
                    aria-label="Table view" title="Table view">
                Table
            </button>
            <button class="view-toggle-btn @(_viewMode == "kanban" ? "active" : "")"
                    @onclick='() => SetViewMode("kanban")'
                    aria-label="Kanban view" title="Kanban view">
                Kanban
            </button>
        </div>
        <button class="btn btn-primary" @onclick="OpenCreate">+ New Task</button>
    </div>
</div>

<!-- Filters & Search bar -->
<div class="filters-bar mb-4">
    <input class="form-control search-input"
           type="search"
           placeholder="Search by title or description..."
           @bind="_search"
           @bind:event="oninput"
           @bind:after="FilterChangedAsync"
           aria-label="Search tasks" />

    <select class="form-control" @bind="_filterProjectId" @bind:after="FilterChangedAsync" aria-label="Filter by project">
        <option value="">All Projects</option>
        @foreach (var p in _projects)
        {
            <option value="@p.Id">@p.Name</option>
        }
    </select>

    <select class="form-control" @bind="_filterStatus" @bind:after="FilterChangedAsync" aria-label="Filter by status">
        <option value="">All Statuses</option>
        @foreach (var s in Enum.GetValues<TaskStatus>())
        {
            <option value="@s">@s</option>
        }
    </select>

    <select class="form-control" @bind="_filterPriority" @bind:after="FilterChangedAsync" aria-label="Filter by priority">
        <option value="">All Priorities</option>
        @foreach (var p in Enum.GetValues<TaskPriority>())
        {
            <option value="@p">@p</option>
        }
    </select>

    <select class="form-control" @bind="_filterAssigneeId" @bind:after="FilterChangedAsync" aria-label="Filter by assignee">
        <option value="">All Assignees</option>
        @foreach (var m in _members)
        {
            <option value="@m.Id">@m.FullName</option>
        }
    </select>

    <select class="form-control" @bind="_sortBy" @bind:after="FilterChangedAsync" aria-label="Sort by">
        <option value="">Sort: Priority</option>
        <option value="dueDate">Sort: Due Date</option>
        <option value="updatedDate">Sort: Last Updated</option>
    </select>
</div>

@if (_loading)
{
    <div class="empty-state"><div class="spinner"></div></div>
}
else if (_tasks.Count == 0 && _viewMode == "table")
{
    <div class="card">
        <div class="empty-state">
            <div class="empty-icon">&#x2705;</div>
            <div class="empty-title">No tasks found</div>
            <div class="empty-sub">
                @if (!string.IsNullOrEmpty(_search) || _filterProjectId != null || _filterStatus != null || _filterPriority != null)
                {
                    <span>Try adjusting your filters</span>
                }
                else
                {
                    <span>Create your first task to get started</span>
                }
            </div>
            @if (string.IsNullOrEmpty(_search))
            {
                <button class="btn btn-primary" style="margin-top:8px;" @onclick="OpenCreate">+ New Task</button>
            }
        </div>
    </div>
}
else
{
    @if (_viewMode == "table")
    {
        <div class="card">
            <div class="table-wrap">
                <table class="tf-table">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Project</th>
                            <th>Status</th>
                            <th>Priority</th>
                            <th>Assignee</th>
                            <th>Due Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in _tasks)
                        {
                            var expanded = _expandedTasks.Contains(t.Id);
                            <tr class="@(IsOverdue(t) ? "overdue-row" : "")">
                                <td>
                                    <div style="display:flex;align-items:center;gap:8px;">
                                        @if (t.SubTasks.Any() || true)
                                        {
                                            <button class="subtask-toggle @(expanded ? "expanded" : "")"
                                                    @onclick="() => ToggleSubTasksAsync(t)"
                                                    title="@GetSubTaskToggleTitle(expanded)">
                                                @(expanded ? "▾" : "▸")
                                            </button>
                                        }
                                        <div>
                                            <div style="color:var(--text);font-weight:500;">@t.Title</div>
                                            @if (!string.IsNullOrEmpty(t.Description))
                                            {
                                                <div class="text-muted" style="font-size:12px;margin-top:2px;">
                                                    @Truncate(t.Description, 60)
                                                </div>
                                            }
                                            @if (t.IsFastClosed)
                                            {
                                                <div style="display:flex;align-items:center;gap:6px;margin-top:3px;">
                                                    <span class="badge badge-blocked" style="font-size:10px;">⚡ Fast-closed</span>
                                                    @if (!string.IsNullOrEmpty(t.CloseReason))
                                                    {
                                                        <span class="text-muted" style="font-size:11px;">@t.CloseReason</span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (t.Project is not null)
                                    {
                                        <span class="badge badge-inprogress">@t.Project.Code</span>
                                    }
                                </td>
                                <td><span class="badge @StatusBadge(t.Status)">@t.Status</span></td>
                                <td><span class="badge @PriorityBadge(t.Priority)">@t.Priority</span></td>
                                <td class="text-dim">
                                    @if (t.Assignee is not null) { @t.Assignee.FullName }
                                    else { <span class="text-muted">Unassigned</span> }
                                </td>
                                <td>
                                    @if (t.DueDate.HasValue)
                                    {
                                        <span class="@(IsOverdue(t) ? "text-danger" : "text-dim")" style="font-size:13px;">
                                            @(IsOverdue(t) ? "⚠️ " : "")@t.DueDate.Value.ToLocalTime().ToString("MMM dd, yyyy")
                                        </span>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td>
                                    <div class="flex gap-2">
                                        @if (t.SubTasks.Any())
                                        {
                                            <span class="badge @SubTaskBadgeClass(t)"
                                                  style="font-size:10px;cursor:pointer;"
                                                  @onclick="() => ToggleSubTasksAsync(t)"
                                                  title="Subtasks: @SubTaskProgress(t)">
                                                ⊞ @SubTaskProgress(t)
                                            </span>
                                        }
                                        <button class="btn btn-ghost btn-sm" @onclick="() => OpenEdit(t)" aria-label="Edit">✏️</button>
                                        <button class="btn btn-ghost btn-sm" @onclick="() => OpenTransition(t)" aria-label="Change status">🔄</button>
                                        <button class="btn btn-danger btn-sm" @onclick="() => ConfirmDelete(t)" aria-label="Delete">🗑️</button>
                                    </div>
                                </td>
                            </tr>

                            @if (expanded)
                            {
                                <tr class="subtask-panel-row">
                                    <td colspan="7">
                                        <div class="subtask-panel">
                                            @foreach (var sub in _subTasks.GetValueOrDefault(t.Id, new()))
                                            {
                                                <div class="subtask-row">
                                                    <button class="subtask-status-btn @StatusBadge(sub.Status)"
                                                            @onclick="() => CycleSubTaskStatusAsync(sub, t.Id)"
                                                            title="@sub.Status — click to advance">
                                                        @(sub.Status == TaskStatus.Done ? "✓" : "○")
                                                    </button>
                                                    <span class="subtask-title @(sub.Status == TaskStatus.Done ? "done" : "")">
                                                        @sub.Title
                                                    </span>
                                                    <span class="badge @PriorityBadge(sub.Priority)" style="font-size:10px;">
                                                        @sub.Priority
                                                    </span>
                                                    <button class="btn btn-ghost btn-sm btn-icon subtask-delete"
                                                            @onclick="() => DeleteSubTaskAsync(sub.Id, t.Id)">🗑️</button>
                                                </div>
                                            }
                                            <div class="subtask-add-row">
                                                <input class="form-control subtask-input" 
                                                       placeholder="New subtask title... (Enter to save)"
                                                       value="@_newSubTaskTitle.GetValueOrDefault(t.Id, string.Empty)"
                                                       @oninput="e => OnSubTaskInput(e, t.Id)"
                                                       @onkeydown="e => OnSubTaskKeyDown(e, t)" />
                                                <button class="btn btn-primary btn-sm"
                                                        disabled="@_savingSubTask.GetValueOrDefault(t.Id, false)"
                                                        @onclick="() => AddSubTaskAsync(t)">
                                                    + Add
                                                </button>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <Pagination T="TaskItem" Result="_result" OnPageChange="GoToPageAsync" />
        </div>
    }
    else
    {
        @if (_dragging)
        {
            <div class="drag-hint">Drop the card into a column to change its status</div>
        }

        <div class="kanban-board">
            @foreach (var status in Enum.GetValues<TaskStatus>())
            {
                var columnTasks  = _tasks.Where(t => t.Status == status).ToList();
                var isDropTarget = _dragOverStatus == status;

                <div class="kanban-column @(isDropTarget ? "kanban-drop-target" : "")"
                     ondragover="event.preventDefault()"
                     @ondragenter="() => OnDragEnter(status)"
                     @ondragleave="OnDragLeave"
                     @ondrop="() => OnDrop(status)">

                    <div class="kanban-column-header">
                        <div class="flex items-center gap-2">
                            <span class="badge @StatusBadge(status)">@status</span>
                            <span class="kanban-count">@columnTasks.Count</span>
                        </div>
                        <button class="btn btn-ghost btn-sm btn-icon"
                                @onclick="() => OpenCreateWithStatus(status)"
                                title="Add task">+</button>
                    </div>

                    <div class="kanban-cards">
                        @if (columnTasks.Count == 0)
                        {
                            <div class="kanban-empty @(isDropTarget ? "kanban-empty-active" : "")">
                                @(isDropTarget ? "Drop here" : "No tasks")
                            </div>
                        }

                        @foreach (var t in columnTasks)
                        {
                            var isDraggingThis = _draggingTaskId == t.Id;
                            var expanded       = _expandedTasks.Contains(t.Id);

                            <div class="kanban-card @(IsOverdue(t) ? "kanban-card-overdue" : "") @(isDraggingThis ? "kanban-card-dragging" : "")"
                                 draggable="true"
                                 @ondragstart="() => OnDragStart(t)"
                                 @ondragend="OnDragEnd">

                                <div class="kanban-card-priority @PriorityBadge(t.Priority)"></div>

                                <div class="kanban-card-body">
                                    <div class="kanban-card-title">@t.Title</div>

                                    @if (!string.IsNullOrEmpty(t.Description))
                                    {
                                        <div class="kanban-card-desc">@Truncate(t.Description, 80)</div>
                                    }

                                    <div class="kanban-card-meta">
                                        @if (t.IsFastClosed)
                                        {
                                            <span class="badge badge-blocked" style="font-size:10px;">⚡ Fast-closed</span>
                                        }
                                        @if (t.Project is not null)
                                        {
                                            <span class="badge badge-inprogress" style="font-size:10px;">@t.Project.Code</span>
                                        }
                                        @if (t.DueDate.HasValue)
                                        {
                                            <span class="@(IsOverdue(t) ? "text-danger" : "text-muted")" style="font-size:11px;">
                                                @(IsOverdue(t) ? "⚠️ " : "📅 ")@t.DueDate.Value.ToLocalTime().ToString("MMM dd")
                                            </span>
                                        }
                                        @if (t.SubTasks.Any())
                                        {
                                            <span class="badge @SubTaskBadgeClass(t)"
                                                  style="font-size:10px;cursor:pointer;"
                                                  @onclick:stopPropagation="true"
                                                  @onclick="() => ToggleSubTasksAsync(t)"
                                                  title="Subtasks: @SubTaskProgress(t)">
                                                ⊞ @SubTaskProgress(t)
                                            </span>
                                        }
                                    </div>

                                    @if (expanded)
                                    {
                                        <div class="subtask-panel kanban-subtask-panel" @onclick:stopPropagation="true">
                                            @foreach (var sub in _subTasks.GetValueOrDefault(t.Id, new()))
                                            {
                                                <div class="subtask-row">
                                                    <button class="subtask-status-btn @StatusBadge(sub.Status)"
                                                            @onclick="() => CycleSubTaskStatusAsync(sub, t.Id)"
                                                            title="@sub.Status">
                                                        @(sub.Status == TaskStatus.Done ? "✓" : "○")
                                                    </button>
                                                    <span class="subtask-title @(sub.Status == TaskStatus.Done ? "done" : "")">
                                                        @sub.Title
                                                    </span>
                                                    <button class="btn btn-ghost btn-sm btn-icon subtask-delete"
                                                            @onclick="() => DeleteSubTaskAsync(sub.Id, t.Id)">🗑️</button>
                                                </div>
                                            }
                                            <div class="subtask-add-row">
                                                <input class="form-control subtask-input"
                                                       placeholder="Add subtask..."
                                                       value="@_newSubTaskTitle.GetValueOrDefault(t.Id, string.Empty)"
                                                       @oninput="e => OnSubTaskInput(e, t.Id)"
                                                       @onkeydown="e => OnSubTaskKeyDown(e, t)" />
                                                <button class="btn btn-primary btn-sm"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="() => AddSubTaskAsync(t)">+</button>
                                            </div>
                                        </div>
                                    }

                                    <div class="kanban-card-footer">
                                        @if (t.Assignee is not null)
                                        {
                                            <div class="kanban-avatar" title="@t.Assignee.FullName">
                                                @GetInitials(t.Assignee.FullName)
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted" style="font-size:11px;">Unassigned</span>
                                        }
                                        <div class="flex gap-2">
                                            <button class="btn btn-ghost btn-sm btn-icon"
                                                    @onclick:stopPropagation="true"
                                                    @onclick="() => ToggleSubTasksAsync(t)"
                                                    title="@GetSubTaskToggleTitle(expanded)">
                                                @(expanded ? "▾" : "▸")
                                            </button>
                                            <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => OpenEdit(t)" title="Edit">✏️</button>
                                            <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => OpenTransition(t)" title="Change status">🔄</button>
                                            <button class="btn btn-danger btn-sm btn-icon" @onclick="() => ConfirmDelete(t)" title="Delete">🗑️</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
}

<!-- Toast notification -->
@if (_message is not null)
{
    <div class="toast-container">
        <div class="alert @(_isError ? "alert-danger" : "alert-success")">
            @(_isError ? "⚠️" : "✅") @_message
        </div>
    </div>
}

<!-- Create / Edit modal -->
@if (_showModal)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal" style="max-width:600px;" @onclick:stopPropagation="true"
             role="dialog" aria-modal="true" aria-labelledby="task-modal-title">
            <div class="modal-header">
                <div class="modal-title" id="task-modal-title">
                    @(_editId is null ? "New Task" : "Edit Task")
                </div>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CloseModal" aria-label="Close">✕</button>
            </div>
            <EditForm Model="_form" OnValidSubmit="SaveAsync">
                <DataAnnotationsValidator />
                <div class="modal-body">
                    @if (_formError is not null)
                    {
                        <div class="alert alert-danger">⚠️ @_formError</div>
                    }
                    @if (IsEditingDone)
                    {
                        <div class="alert alert-danger">🔒 This task is Done and cannot be edited.</div>
                    }
                    else if (IsEditingBlocked)
                    {
                        <div class="alert alert-danger">🚧 This task is Blocked. Only title and description can be edited.</div>
                    }
                    <div class="form-group">
                        <label class="form-label" for="ttitle">Title *</label>
                        <InputText id="ttitle" class="form-control" @bind-Value="_form.Title"
                                   placeholder="e.g. Fix login bug" autocomplete="off" disabled="@IsEditingDone" />
                        <ValidationMessage For="() => _form.Title" class="validation-message" />
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="tdesc">Description</label>
                        <InputTextArea id="tdesc" class="form-control" @bind-Value="_form.Description"
                                       placeholder="Optional details..." rows="3" disabled="@IsEditingDone"/>
                        <ValidationMessage For="() => _form.Description" class="validation-message" />
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                        <div class="form-group">
                            <label class="form-label" for="tproject">Project *</label>
                            <InputSelect id="tproject" class="form-control" @bind-Value="_form.ProjectId" disabled="@(IsEditingBlocked || IsEditingDone)">
                                <option value="0">— Select project —</option>
                                @foreach (var p in _projects)
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => _form.ProjectId" class="validation-message" />
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="tassignee">Assignee</label>
                            <InputSelect id="tassignee" class="form-control" @bind-Value="_form.AssigneeId" disabled="@(IsEditingBlocked || IsEditingDone)">
                                <option value="">— Unassigned —</option>
                                @foreach (var m in _members.Where(m => m.IsActive))
                                {
                                    <option value="@m.Id">@m.FullName</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                        <div class="form-group">
                            <label class="form-label" for="tpriority">Priority</label>
                            <InputSelect id="tpriority" class="form-control" @bind-Value="_form.Priority" disabled="@(IsEditingBlocked || IsEditingDone)">
                                @foreach (var p in Enum.GetValues<TaskPriority>())
                                {
                                    <option value="@p">@p</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="tduedate">Due Date</label>
                            <InputDate id="tduedate" class="form-control" @bind-Value="_form.DueDate" disabled="@(IsEditingBlocked || IsEditingDone)" />
                        </div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                        <div class="form-group">
                            <label class="form-label" for="testimated">Estimated Hours</label>
                            <InputNumber id="testimated" class="form-control"
                                         @bind-Value="_form.EstimatedHours" placeholder="e.g. 4.5" disabled="@(IsEditingBlocked || IsEditingDone)"/>
                            <ValidationMessage For="() => _form.EstimatedHours" class="validation-message" />
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="tactual">Actual Hours</label>
                            <InputNumber id="tactual" class="form-control"
                                         @bind-Value="_form.ActualHours" placeholder="e.g. 3.0" disabled="@(IsEditingBlocked || IsEditingDone)"/>
                            <ValidationMessage For="() => _form.ActualHours" class="validation-message" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="btn btn-primary" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="spinner" style="width:14px;height:14px;border-width:2px;"></span>
                        }
                        @(_editId is null ? "Create Task" : "Save Changes")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

<!-- Status transition modal -->
@if (_showTransitionModal && _transitionTask is not null)
{
    <div class="modal-backdrop" @onclick="CloseTransitionModal">
        <div class="modal" style="max-width:420px;" @onclick:stopPropagation="true"
             role="dialog" aria-modal="true" aria-labelledby="transition-title">
            <div class="modal-header">
                <div class="modal-title" id="transition-title">Change Status</div>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CloseTransitionModal">✕</button>
            </div>
            <div class="modal-body">
                <p class="text-dim" style="margin-bottom:16px;">
                    Task: <strong style="color:var(--text);">@_transitionTask.Title</strong>
                </p>
                <p class="text-dim" style="margin-bottom:12px;font-size:12px;">
                    Current: <span class="badge @StatusBadge(_transitionTask.Status)">@_transitionTask.Status</span>
                </p>
                @if (_transitionError is not null)
                {
                    <div class="alert alert-danger">⚠️ @_transitionError</div>
                }
                <div style="display:flex;flex-direction:column;gap:8px;">
                    @foreach (var transition in GetAvailableTransitions(_transitionTask.Status))
                    {
                        <button class="btn @TransitionBtnClass(transition.To) w-full"
                                @onclick="() => ApplyTransitionAsync(transition.To)">
                            @TransitionIcon(transition.To) @transition.Label
                            <span style="font-size:11px;opacity:.7;margin-left:4px;">— @transition.Description</span>
                        </button>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseTransitionModal">Cancel</button>
            </div>
        </div>
    </div>
}

<!-- Delete confirmation modal -->
@if (_showDeleteModal && _deleteTarget is not null)
{
    <div class="modal-backdrop" @onclick="CloseDeleteModal">
        <div class="modal" style="max-width:400px;" @onclick:stopPropagation="true"
             role="dialog" aria-modal="true" aria-labelledby="delete-title">
            <div class="modal-header">
                <div class="modal-title" id="delete-title" style="color:var(--danger);">🗑️ Delete Task</div>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CloseDeleteModal">✕</button>
            </div>
            <div class="modal-body">
                <p class="text-dim">
                    Are you sure you want to delete
                    <strong style="color:var(--text);">@_deleteTarget.Title</strong>?
                    This action cannot be undone.
                </p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseDeleteModal">Cancel</button>
                <button class="btn btn-danger" @onclick="DeleteAsync" disabled="@_saving">
                    @if (_saving) { <span class="spinner" style="width:14px;height:14px;border-width:2px;"></span> }
                    Yes, Delete
                </button>
            </div>
        </div>
    </div>
}

<!-- Reason modal -->
@if (_showReasonModal && _transitionTask is not null)
{
    <div class="modal-backdrop" @onclick="() => _showReasonModal = false">
        <div class="modal" style="max-width:420px;" @onclick:stopPropagation="true"
             role="dialog" aria-modal="true">
            <div class="modal-header">
                <div class="modal-title">Reason Required</div>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => _showReasonModal = false">✕</button>
            </div>
            <div class="modal-body">
                <p class="text-dim" style="margin-bottom:12px;">
                    Moving <strong style="color:var(--text);">@_transitionTask.Title</strong>
                    to <span class="badge @StatusBadge(_pendingStatus)">@_pendingStatus</span>
                </p>
                @if (StateMachine.IsFastClose(_transitionTask.Status, _pendingStatus))
                {
                   <div class="alert alert-danger" style="margin-bottom:12px; white-space:normal;",>
                        ⚡ This task will be marked as <strong>fast-closed</strong> — it skipped the normal workflow.
                    </div>
                }
                @if (_reasonError is not null)
                {
                    <div class="alert alert-danger">⚠️ @_reasonError</div>
                }
                <div class="form-group">
                    <label class="form-label">Select a reason *</label>
                    <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:12px;">
                        @foreach (var reason in CloseReasons)
                        {
                            <button class="btn @(_reasonInput == reason ? "btn-primary" : "btn-ghost") w-full"
                                    style="justify-content:flex-start;"
                                    @onclick="() => { _reasonInput = reason; _reasonError = null; }">
                                @reason
                            </button>
                        }
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="() => _showReasonModal = false">Cancel</button>
                <button class="btn btn-primary" @onclick="ConfirmReasonAsync"
                        disabled="@string.IsNullOrEmpty(_reasonInput)">
                    Confirm
                </button>
            </div>
        </div>
    </div>
}

